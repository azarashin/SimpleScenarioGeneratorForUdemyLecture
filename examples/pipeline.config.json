{
  "model_name": "gpt-5.3-codex",
  "temperature_policy": {
    "low_temperature": 0.2,
    "diversity_temperature": 0.7,
    "diversity_steps": [
      "step-02-generate-outline",
      "step-03-generate-sections"
    ]
  },
  "prompt_versions": {
    "step-01-generate-character-profiles": "v1",
    "step-02-generate-outline": "v1",
    "step-03-generate-sections": "v1"
  },
  "retry_strategy": {
    "short_retries": 1,
    "prompt_revision_retries": 1,
    "fallback_enabled": true
  },
  "output_root": "output",
  "artifacts_dir_name": "artifacts",
  "state_file_name": "run-state.json",
  "trace_file_name": "trace.jsonl",
  "image_generation": {
    "provider": "mock",
    "model": "image-mock-v1",
    "width": 1024,
    "height": 1024,
    "style_preset": "anime"
  }
}
