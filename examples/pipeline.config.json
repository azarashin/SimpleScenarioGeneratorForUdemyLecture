{
  "text_generation": {
    "provider": "mock",
    "model": "gpt-5.3-codex",
    "timeout_seconds": 60,
    "api_key_env": "TEXT_GENERATION_API_KEY"
  },
  "character_profile_generation": {
    "enabled": false,
    "require_review": true
  },
  "planning_input_generation": {
    "enabled": false,
    "require_review": true
  },
  "scenario_body_generation": {
    "subsections_per_section": 3,
    "target_characters": 1200,
    "min_characters": 1000,
    "max_characters": 1600,
    "min_dialogue_blocks": 6,
    "max_dialogue_blocks": 14,
    "require_event_mentions": true
  },
  "temperature_policy": {
    "low_temperature": 0.2,
    "diversity_temperature": 0.7,
    "diversity_steps": [
      "step-02-generate-outline",
      "step-04-generate-sections"
    ]
  },
  "prompt_versions": {
    "step-01-generate-character-profiles": "v1",
    "step-02-generate-outline": "v1",
    "step-03-generate-character-images": "v2",
    "step-04-generate-sections": "v2"
  },
  "retry_strategy": {
    "short_retries": 1,
    "prompt_revision_retries": 1,
    "fallback_enabled": true
  },
  "output_root": "output",
  "artifacts_dir_name": "artifacts",
  "state_file_name": "run-state.json",
  "trace_file_name": "trace.jsonl",
  "image_generation": {
    "provider": "mock",
    "model": "chat-gpt-image-2",
    "width": 1024,
    "height": 1024,
    "expression_sheet_width": 2048,
    "expression_sheet_height": 2048,
    "style_preset": "anime",
    "quality": "high",
    "output_format": "png",
    "timeout_seconds": 120,
    "api_key_env": "OPENAI_API_KEY"
  }
}
