{
    "text_generation": {
        "provider": "openai",
        "model": "gpt-5.3-codex",
        "timeout_seconds": 120,
        "api_key_env": "OPENAI_API_KEY"
    },
    "scenario_body_generation": {
        "min_characters": 1000,
        "max_characters": 3200,
        "min_dialogue_blocks": 20,
        "max_dialogue_blocks": 40,
        "require_event_mentions": true
    },
    "temperature_policy": {
        "low_temperature": 0.2,
        "diversity_temperature": 0.7,
        "diversity_steps": [
            "step-02-generate-outline",
            "step-04-generate-sections"
        ]
    },
    "prompt_versions": {
        "step-01-generate-character-profiles": "v1",
        "step-02-generate-outline": "v1",
        "step-04-generate-sections": "v2"
    },
    "retry_strategy": {
        "short_retries": 1,
        "prompt_revision_retries": 2,
        "fallback_enabled": true
    },
    "output_root": "output",
    "artifacts_dir_name": "artifacts",
    "state_file_name": "run-state.json",
    "trace_file_name": "trace.jsonl",
    "image_generation": {
        "provider": "mock",
        "model": "chat-gpt-image-2",
        "width": 1024,
        "height": 1024,
        "style_preset": "anime"
    }
}
