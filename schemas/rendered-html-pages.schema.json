{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.local/schemas/rendered-html-pages.schema.json",
    "title": "Rendered HTML Pages Manifest",
    "description": "HTMLファイル群そのものではなく、生成結果のマニフェストを検証するスキーマ。",
    "type": "object",
    "required": [
        "index_path",
        "chapter_pages",
        "section_pages"
    ],
    "additionalProperties": false,
    "properties": {
        "index_path": {
            "$ref": "common.schema.json#/$defs/filePath"
        },
        "chapter_pages": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "chapter_no",
                    "path"
                ],
                "additionalProperties": false,
                "properties": {
                    "chapter_no": {
                        "$ref": "common.schema.json#/$defs/positiveInteger"
                    },
                    "path": {
                        "$ref": "common.schema.json#/$defs/filePath"
                    }
                }
            }
        },
        "section_pages": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "chapter_no",
                    "section_no",
                    "path"
                ],
                "additionalProperties": false,
                "properties": {
                    "chapter_no": {
                        "$ref": "common.schema.json#/$defs/positiveInteger"
                    },
                    "section_no": {
                        "$ref": "common.schema.json#/$defs/positiveInteger"
                    },
                    "path": {
                        "$ref": "common.schema.json#/$defs/filePath"
                    }
                }
            }
        }
    }
}