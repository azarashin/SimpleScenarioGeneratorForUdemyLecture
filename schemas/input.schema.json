{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/input.schema.json",
  "title": "Pipeline Input",
  "type": "object",
  "required": ["scenario_idea", "character_overviews"],
  "additionalProperties": false,
  "properties": {
    "scenario_idea": {
      "type": "object",
      "required": ["title", "genre", "theme", "premise", "target_length"],
      "additionalProperties": false,
      "properties": {
        "title": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "genre": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "theme": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "premise": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "tone": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "must_include": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        },
        "must_avoid": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        },
        "audience": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "target_length": {
          "type": "object",
          "required": ["chapter_count", "sections_per_chapter"],
          "additionalProperties": false,
          "properties": {
            "chapter_count": { "$ref": "common.schema.json#/$defs/positiveInteger" },
            "sections_per_chapter": { "$ref": "common.schema.json#/$defs/positiveInteger" }
          }
        }
      }
    },
    "character_overviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["character_id", "name", "role", "summary"],
        "additionalProperties": false,
        "properties": {
          "character_id": { "$ref": "common.schema.json#/$defs/characterId" },
          "name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "role": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "summary": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "age_range": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "gender": {
            "type": "string",
            "enum": ["unknown", "male", "female", "other"]
          },
          "position": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "speech_style_hint": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "appearance_hint": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "costume": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "standing_pose": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "image_prompt_hint": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "background_hint": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "personality_traits": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "values": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "strengths": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "weaknesses": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "relationship_to_protagonist": {
            "$ref": "common.schema.json#/$defs/nonEmptyString"
          },
          "conversation_role": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "growth_arc": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "speech_profile": {
            "type": "object",
            "required": [
              "style",
              "sentence_length",
              "politeness_level",
              "first_person",
              "second_person",
              "common_phrases",
              "forbidden_phrases",
              "sample_lines"
            ],
            "additionalProperties": false,
            "properties": {
              "style": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "sentence_length": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "politeness_level": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "first_person": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "second_person": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "common_phrases": {
                "type": "array",
                "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
              },
              "forbidden_phrases": {
                "type": "array",
                "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
              },
              "sample_lines": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
              }
            }
          },
          "relationship_hints": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "target_character_id",
                "relationship",
                "attitude",
                "addressing_style"
              ],
              "additionalProperties": false,
              "properties": {
                "target_character_id": { "$ref": "common.schema.json#/$defs/characterId" },
                "relationship": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
                "attitude": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
                "addressing_style": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
              }
            }
          },
          "emotion_range": {
            "type": "array",
            "minItems": 1,
            "contains": { "const": "neutral" },
            "items": { "$ref": "common.schema.json#/$defs/expression" }
          },
          "expression_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["condition", "expression"],
              "additionalProperties": false,
              "properties": {
                "condition": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
                "expression": { "$ref": "common.schema.json#/$defs/expression" }
              }
            }
          }
        }
      },
      "uniqueItems": true
    }
  }
}
