{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.local/schemas/scenario-outline.schema.json",
    "title": "Scenario Outline",
    "type": "object",
    "required": [
        "title",
        "logline",
        "chapters"
    ],
    "additionalProperties": false,
    "properties": {
        "title": {
            "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "logline": {
            "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "chapters": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "chapter_no",
                    "chapter_title",
                    "chapter_goal",
                    "sections"
                ],
                "additionalProperties": false,
                "properties": {
                    "chapter_no": {
                        "$ref": "common.schema.json#/$defs/positiveInteger"
                    },
                    "chapter_title": {
                        "$ref": "common.schema.json#/$defs/nonEmptyString"
                    },
                    "chapter_goal": {
                        "$ref": "common.schema.json#/$defs/nonEmptyString"
                    },
                    "sections": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "required": [
                                "section_no",
                                "section_title",
                                "section_purpose",
                                "key_events",
                                "participating_characters"
                            ],
                            "additionalProperties": false,
                            "properties": {
                                "section_no": {
                                    "$ref": "common.schema.json#/$defs/positiveInteger"
                                },
                                "section_title": {
                                    "$ref": "common.schema.json#/$defs/nonEmptyString"
                                },
                                "section_purpose": {
                                    "$ref": "common.schema.json#/$defs/nonEmptyString"
                                },
                                "key_events": {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": {
                                        "$ref": "common.schema.json#/$defs/nonEmptyString"
                                    }
                                },
                                "participating_characters": {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": {
                                        "$ref": "common.schema.json#/$defs/characterId"
                                    }
                                },
                                "subsections": {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": {
                                        "type": "object",
                                        "required": [
                                            "subsection_no",
                                            "subsection_title",
                                            "subsection_purpose",
                                            "key_events"
                                        ],
                                        "additionalProperties": false,
                                        "properties": {
                                            "subsection_no": {
                                                "$ref": "common.schema.json#/$defs/positiveInteger"
                                            },
                                            "subsection_title": {
                                                "$ref": "common.schema.json#/$defs/nonEmptyString"
                                            },
                                            "subsection_purpose": {
                                                "$ref": "common.schema.json#/$defs/nonEmptyString"
                                            },
                                            "key_events": {
                                                "type": "array",
                                                "minItems": 1,
                                                "items": {
                                                    "$ref": "common.schema.json#/$defs/nonEmptyString"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
