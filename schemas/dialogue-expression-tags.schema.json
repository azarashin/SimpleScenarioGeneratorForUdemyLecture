{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/dialogue-expression-tags.schema.json",
  "title": "Dialogue Expression Tags",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "chapter_no",
      "section_no",
      "block_id",
      "speaker_id",
      "expression",
      "emotion_reason"
    ],
    "additionalProperties": false,
    "properties": {
      "chapter_no": { "$ref": "common.schema.json#/$defs/positiveInteger" },
      "section_no": { "$ref": "common.schema.json#/$defs/positiveInteger" },
      "block_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "speaker_id": { "$ref": "common.schema.json#/$defs/characterId" },
      "expression": { "$ref": "common.schema.json#/$defs/expression" },
      "emotion_reason": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    }
  }
}
