{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.local/schemas/scenario-sections.schema.json",
    "title": "Scenario Sections",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "required": [
            "chapter_no",
            "section_no",
            "section_title",
            "narrative_blocks"
        ],
        "additionalProperties": false,
        "properties": {
            "chapter_no": {
                "$ref": "common.schema.json#/$defs/positiveInteger"
            },
            "section_no": {
                "$ref": "common.schema.json#/$defs/positiveInteger"
            },
            "section_title": {
                "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "narrative_blocks": {
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "object",
                    "required": [
                        "block_id",
                        "type",
                        "text",
                        "speaker_id"
                    ],
                    "additionalProperties": false,
                    "properties": {
                        "block_id": {
                            "$ref": "common.schema.json#/$defs/nonEmptyString"
                        },
                        "type": {
                            "type": "string",
                            "enum": [
                                "narration",
                                "dialogue"
                            ]
                        },
                        "text": {
                            "$ref": "common.schema.json#/$defs/nonEmptyString"
                        },
                        "speaker_id": {
                            "oneOf": [
                                {
                                    "type": "null"
                                },
                                {
                                    "$ref": "common.schema.json#/$defs/characterId"
                                }
                            ]
                        }
                    },
                    "allOf": [
                        {
                            "if": {
                                "properties": {
                                    "type": {
                                        "const": "dialogue"
                                    }
                                },
                                "required": [
                                    "type"
                                ]
                            },
                            "then": {
                                "properties": {
                                    "speaker_id": {
                                        "$ref": "common.schema.json#/$defs/characterId"
                                    }
                                }
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "type": {
                                        "const": "narration"
                                    }
                                },
                                "required": [
                                    "type"
                                ]
                            },
                            "then": {
                                "properties": {
                                    "speaker_id": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    ]
                }
            }
        }
    }
}