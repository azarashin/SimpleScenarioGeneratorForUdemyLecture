{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.local/schemas/scenario-sections.schema.json",
    "title": "Scenario Sections",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "required": [
            "chapter_no",
            "section_no",
            "section_title",
            "narrative_blocks",
            "state_updates"
        ],
        "additionalProperties": false,
        "properties": {
            "chapter_no": {
                "$ref": "common.schema.json#/$defs/positiveInteger"
            },
            "section_no": {
                "$ref": "common.schema.json#/$defs/positiveInteger"
            },
            "section_title": {
                "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "narrative_blocks": {
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "object",
                    "required": [
                        "block_id",
                        "type",
                        "text",
                        "speaker_id"
                    ],
                    "additionalProperties": false,
                    "properties": {
                        "block_id": {
                            "$ref": "common.schema.json#/$defs/nonEmptyString"
                        },
                        "type": {
                            "type": "string",
                            "enum": [
                                "narration",
                                "dialogue"
                            ]
                        },
                        "text": {
                            "$ref": "common.schema.json#/$defs/nonEmptyString"
                        },
                        "speaker_id": {
                            "oneOf": [
                                {
                                    "type": "null"
                                },
                                {
                                    "$ref": "common.schema.json#/$defs/characterId"
                                }
                            ]
                        }
                    },
                    "allOf": [
                        {
                            "if": {
                                "properties": {
                                    "type": {
                                        "const": "dialogue"
                                    }
                                },
                                "required": [
                                    "type"
                                ]
                            },
                            "then": {
                                "properties": {
                                    "speaker_id": {
                                        "$ref": "common.schema.json#/$defs/characterId"
                                    }
                                }
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "type": {
                                        "const": "narration"
                                    }
                                },
                                "required": [
                                    "type"
                                ]
                            },
                            "then": {
                                "properties": {
                                    "speaker_id": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    ]
                }
            },
            "state_updates": {
                "type": "object",
                "required": [
                    "character_locations",
                    "possessions",
                    "known_information",
                    "relationship_changes",
                    "introduced_entities",
                    "unresolved_plot_threads",
                    "resolved_plot_threads",
                    "continuity_summary"
                ],
                "additionalProperties": false,
                "properties": {
                    "character_locations": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["character_id", "location"],
                            "additionalProperties": false,
                            "properties": {
                                "character_id": {"$ref": "common.schema.json#/$defs/characterId"},
                                "location": {
                                    "oneOf": [
                                        {"type": "null"},
                                        {"$ref": "common.schema.json#/$defs/nonEmptyString"}
                                    ]
                                }
                            }
                        }
                    },
                    "possessions": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["character_id", "items"],
                            "additionalProperties": false,
                            "properties": {
                                "character_id": {"$ref": "common.schema.json#/$defs/characterId"},
                                "items": {
                                    "type": "array",
                                    "items": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
                                }
                            }
                        }
                    },
                    "known_information": {
                        "type": "array",
                        "items": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
                    },
                    "relationship_changes": {
                        "type": "array",
                        "items": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
                    },
                    "introduced_entities": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["entity_id", "type", "name", "description"],
                            "additionalProperties": false,
                            "properties": {
                                "entity_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
                                "type": {"enum": ["character", "location", "organization", "object", "concept"]},
                                "name": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
                                "description": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
                            }
                        }
                    },
                    "unresolved_plot_threads": {
                        "type": "array",
                        "items": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
                    },
                    "resolved_plot_threads": {
                        "type": "array",
                        "items": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
                    },
                    "continuity_summary": {
                        "$ref": "common.schema.json#/$defs/nonEmptyString"
                    }
                }
            }
        }
    }
}
