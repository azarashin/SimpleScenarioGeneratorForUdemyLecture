{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Character Profile Generation",
  "type": "object",
  "required": ["character_profiles"],
  "additionalProperties": false,
  "properties": {
    "character_profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/characterProfile" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "relationship": {
      "type": "object",
      "required": ["target_character_id", "relationship", "attitude", "addressing_style"],
      "additionalProperties": false,
      "properties": {
        "target_character_id": { "$ref": "#/$defs/nonEmptyString" },
        "relationship": { "$ref": "#/$defs/nonEmptyString" },
        "attitude": { "$ref": "#/$defs/nonEmptyString" },
        "addressing_style": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "expressionRule": {
      "type": "object",
      "required": ["condition", "expression"],
      "additionalProperties": false,
      "properties": {
        "condition": { "$ref": "#/$defs/nonEmptyString" },
        "expression": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "characterProfile": {
      "type": "object",
      "required": [
        "character_id", "name", "role", "personality", "speech", "appearance",
        "background", "narrative", "relationships", "emotion_model"
      ],
      "additionalProperties": false,
      "properties": {
        "character_id": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "personality": {
          "type": "object",
          "required": ["core_traits", "values", "strengths", "weaknesses"],
          "additionalProperties": false,
          "properties": {
            "core_traits": { "$ref": "#/$defs/stringArray" },
            "values": { "$ref": "#/$defs/stringArray" },
            "strengths": { "$ref": "#/$defs/stringArray" },
            "weaknesses": { "$ref": "#/$defs/stringArray" }
          }
        },
        "speech": {
          "type": "object",
          "required": [
            "style", "sentence_length", "politeness_level", "first_person",
            "second_person", "verbal_tics", "forbidden_phrases", "sample_lines"
          ],
          "additionalProperties": false,
          "properties": {
            "style": { "$ref": "#/$defs/nonEmptyString" },
            "sentence_length": { "$ref": "#/$defs/nonEmptyString" },
            "politeness_level": { "$ref": "#/$defs/nonEmptyString" },
            "first_person": { "$ref": "#/$defs/nonEmptyString" },
            "second_person": { "$ref": "#/$defs/nonEmptyString" },
            "verbal_tics": { "$ref": "#/$defs/stringArray" },
            "forbidden_phrases": { "$ref": "#/$defs/stringArray" },
            "sample_lines": {
              "type": "array",
              "minItems": 3,
              "items": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        },
        "appearance": {
          "type": "object",
          "required": [
            "age_impression", "gender", "position", "features", "costume",
            "standing_pose", "image_prompt_hint"
          ],
          "additionalProperties": false,
          "properties": {
            "age_impression": { "$ref": "#/$defs/nonEmptyString" },
            "gender": { "type": "string", "enum": ["unknown", "male", "female", "other"] },
            "position": { "$ref": "#/$defs/nonEmptyString" },
            "features": { "$ref": "#/$defs/stringArray" },
            "costume": { "$ref": "#/$defs/nonEmptyString" },
            "standing_pose": { "$ref": "#/$defs/nonEmptyString" },
            "image_prompt_hint": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "background": { "$ref": "#/$defs/nonEmptyString" },
        "narrative": {
          "type": "object",
          "required": ["conversation_role", "growth_arc", "relationship_to_protagonist"],
          "additionalProperties": false,
          "properties": {
            "conversation_role": { "$ref": "#/$defs/nonEmptyString" },
            "growth_arc": { "$ref": "#/$defs/nonEmptyString" },
            "relationship_to_protagonist": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/relationship" }
        },
        "emotion_model": {
          "type": "object",
          "required": ["available_expressions", "preferred_expressions", "expression_rules"],
          "additionalProperties": false,
          "properties": {
            "available_expressions": {
              "type": "array",
              "minItems": 16,
              "maxItems": 16,
              "items": {
                "type": "string",
                "enum": [
                  "neutral", "smile", "serious", "thinking", "surprised", "worried",
                  "confused", "angry", "sad", "relieved", "embarrassed", "nervous",
                  "confident", "doubtful", "shocked", "determined"
                ]
              }
            },
            "preferred_expressions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/nonEmptyString" }
            },
            "expression_rules": {
              "type": "array",
              "items": { "$ref": "#/$defs/expressionRule" }
            }
          }
        }
      }
    }
  }
}
