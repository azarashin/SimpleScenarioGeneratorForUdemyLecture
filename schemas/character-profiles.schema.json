{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/character-profiles.schema.json",
  "title": "Character Profiles",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "character_id",
      "name",
      "role",
      "personality",
      "speech",
      "appearance",
      "emotion_model"
    ],
    "additionalProperties": false,
    "properties": {
      "character_id": { "$ref": "common.schema.json#/$defs/characterId" },
      "name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "role": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "personality": {
        "type": "object",
        "required": ["core_traits", "values", "weaknesses"],
        "additionalProperties": false,
        "properties": {
          "core_traits": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "values": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "weaknesses": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "strengths": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          }
        }
      },
      "speech": {
        "type": "object",
        "required": ["style", "first_person", "verbal_tics"],
        "additionalProperties": false,
        "properties": {
          "style": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "first_person": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "second_person": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "sentence_length": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "politeness_level": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "verbal_tics": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "forbidden_phrases": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "sample_lines": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          }
        }
      },
      "appearance": {
        "type": "object",
        "required": ["age_impression", "features", "costume"],
        "additionalProperties": false,
        "properties": {
          "age_impression": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "gender": {
            "type": "string",
            "enum": ["unknown", "male", "female", "other"]
          },
          "position": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "features": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "costume": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "standing_pose": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "image_prompt_hint": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        }
      },
      "emotion_model": {
        "type": "object",
        "required": ["available_expressions"],
        "additionalProperties": false,
        "properties": {
          "available_expressions": {
            "type": "array",
            "minItems": 1,
            "contains": { "const": "neutral" },
            "items": { "$ref": "common.schema.json#/$defs/expression" }
          },
          "preferred_expressions": {
            "type": "array",
            "minItems": 1,
            "contains": { "const": "neutral" },
            "items": { "$ref": "common.schema.json#/$defs/expression" }
          },
          "expression_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["condition", "expression"],
              "additionalProperties": false,
              "properties": {
                "condition": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
                "expression": { "$ref": "common.schema.json#/$defs/expression" }
              }
            }
          }
        }
      },
      "background": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "narrative": {
        "type": "object",
        "required": ["conversation_role", "growth_arc", "relationship_to_protagonist"],
        "additionalProperties": false,
        "properties": {
          "conversation_role": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "growth_arc": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "relationship_to_protagonist": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        }
      },
      "relationships": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["target_character_id", "relationship", "attitude", "addressing_style"],
          "additionalProperties": false,
          "properties": {
            "target_character_id": { "$ref": "common.schema.json#/$defs/characterId" },
            "relationship": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
            "attitude": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
            "addressing_style": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          }
        }
      }
    }
  },
  "uniqueItems": true
}
