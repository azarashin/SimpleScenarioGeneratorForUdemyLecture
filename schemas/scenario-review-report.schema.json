{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/scenario-review-report.schema.json",
  "title": "Scenario Review Report",
  "type": "object",
  "required": ["passed", "score", "repair_scope", "findings"],
  "additionalProperties": false,
  "properties": {
    "passed": {"type": "boolean"},
    "score": {"type": "integer", "minimum": 0, "maximum": 100},
    "repair_scope": {"enum": ["none", "local", "section", "outline"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "category", "block_ids", "problem", "repair_instruction"],
        "additionalProperties": false,
        "properties": {
          "severity": {"enum": ["info", "warning", "critical"]},
          "category": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
          "block_ids": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/nonEmptyString"}},
          "problem": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
          "repair_instruction": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
        }
      }
    }
  }
}
