{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/dialogue-speaker-image-rendering.schema.json",
  "title": "Dialogue Speaker Image Rendering",
  "description": "節ページ内のセリフ表示マッピングを検証する。",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "chapter_no",
      "section_no",
      "block_id",
      "speaker_id",
      "speaker_name",
      "expression",
      "image_path",
      "alt"
    ],
    "additionalProperties": false,
    "properties": {
      "chapter_no": { "$ref": "common.schema.json#/$defs/positiveInteger" },
      "section_no": { "$ref": "common.schema.json#/$defs/positiveInteger" },
      "block_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "speaker_id": { "$ref": "common.schema.json#/$defs/characterId" },
      "speaker_name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "expression": { "$ref": "common.schema.json#/$defs/expression" },
      "image_path": {
        "oneOf": [
          { "$ref": "common.schema.json#/$defs/filePath" },
          { "type": "null" }
        ]
      },
      "alt": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "is_fallback": { "type": "boolean", "default": false }
    }
  }
}
